{
    "name": "kholil/filament-analitik",
    "description": "Simple page analytics for Filament v4/v5",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Kholil",
            "email": "kholil@example.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "illuminate/contracts": "^12.0|^13.0",
        "stevebauman/location": "^7.6"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "pestphp/pest": "^2.0|^3.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0"
    },
    "autoload": {
        "psr-4": {
            "Kholil\\FilamentAnalitik\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kholil\\FilamentAnalitik\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Kholil\\FilamentAnalitik\\FilamentAnalitikServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
